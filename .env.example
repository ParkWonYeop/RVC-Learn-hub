# RVC Training Orchestrator deployment defaults.
#
# Copy this file only for local development. Production installers create a
# mode-0600 environment file and independent mode-0600 secret files; passwords
# and tokens must never be added here.

COMPOSE_PROJECT_NAME=rvc-orchestrator-manager
ORCHESTRATOR_VERSION=dev
ENVIRONMENT=development
ALLOW_FAKE_WORKERS=true
LOG_LEVEL=INFO
TZ=UTC

# Release images. Override these with immutable registry tags or digests.
API_IMAGE=rvc-orchestrator-api:dev
WEB_IMAGE=rvc-orchestrator-web:dev
WORKER_IMAGE=rvc-orchestrator-worker:dev
MLFLOW_IMAGE=rvc-orchestrator-mlflow:dev
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7.4-alpine
MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_CLIENT_IMAGE=minio/mc:RELEASE.2025-04-16T18-13-26Z
NGINX_IMAGE=nginx:1.27-alpine
RVC_IMAGE_PULL_POLICY=missing

# Manager network-facing settings.
HTTP_BIND_ADDRESS=127.0.0.1
HTTP_PORT=8080
MINIO_API_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND_ADDRESS=127.0.0.1
MINIO_CONSOLE_PORT=9001
MLFLOW_BIND_ADDRESS=127.0.0.1
MLFLOW_PORT=5000
PUBLIC_SERVER_NAME=localhost
# Browser-facing scheme after the trusted edge/TLS terminator. The production
# Manager start gate requires https; local --no-start validation may use http.
PUBLIC_SCHEME=http
CLIENT_MAX_BODY_SIZE=20g
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
RATE_LIMIT_ENABLED=true
RATE_LIMIT_FAIL_CLOSED=true
RATE_LIMIT_DEFAULT_REQUESTS_PER_MINUTE=600
RATE_LIMIT_LOGIN_REQUESTS_PER_MINUTE=10
RATE_LIMIT_REGISTER_REQUESTS_PER_MINUTE=10
RATE_LIMIT_WORKER_TOKEN_ROTATION_REQUESTS_PER_MINUTE=6
RATE_LIMIT_UPLOAD_REQUESTS_PER_MINUTE=120
RATE_LIMIT_FINALIZE_REQUESTS_PER_MINUTE=30

# Non-secret service settings.
POSTGRES_DB=rvc_orchestrator
POSTGRES_USER=rvc_manager
MAINTENANCE_POSTGRES_USER=rvc_maintenance
MLFLOW_POSTGRES_DB=rvc_mlflow
MLFLOW_POSTGRES_USER=rvc_mlflow
REDIS_DB=0
MAINTENANCE_REDIS_USER=rvc_maintenance
RQ_ENABLED=true
RQ_QUEUE_NAME=rvc-maintenance
RQ_READINESS_TIMEOUT_SECONDS=2
RQ_WORKER_HEARTBEAT_MAX_AGE_SECONDS=75
RQ_WORKER_TTL_SECONDS=45
MAINTENANCE_CLEANUP_GRACE_SECONDS=604800
MAINTENANCE_CLEANUP_BATCH_SIZE=250
MAINTENANCE_TASK_TIMEOUT_SECONDS=300
MAINTENANCE_TASK_HEARTBEAT_SECONDS=15
MAINTENANCE_TASK_MAX_ATTEMPTS=3
MAINTENANCE_RETRY_BACKOFF_SECONDS=30
MAINTENANCE_RETRY_BACKOFF_MAX_SECONDS=300
MAINTENANCE_CLEANUP_CLAIM_STALE_SECONDS=900
MAINTENANCE_RECONCILE_ENABLED=true
MAINTENANCE_RECONCILE_INTERVAL_SECONDS=15
MAINTENANCE_RECONCILE_STALE_SECONDS=120
MAINTENANCE_RECONCILE_BATCH_SIZE=100
STORAGE_BACKEND=s3
S3_PRESIGN_ENDPOINT_URL=http://127.0.0.1:9000
S3_BUCKET=rvc-orchestrator
MLFLOW_S3_BUCKET=rvc-mlflow
MLFLOW_ENABLED=true
MLFLOW_FAIL_CLOSED=false
MLFLOW_REQUEST_TIMEOUT_SECONDS=5
MLFLOW_READINESS_TIMEOUT_SECONDS=1
MLFLOW_SYNC_INTERVAL_SECONDS=5
MLFLOW_SYNC_BATCH_SIZE=20
MLFLOW_PROCESSING_STALE_SECONDS=120
MLFLOW_RETRY_MAX_SECONDS=300
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path
S3_VERIFY_TLS=true
S3_PRESIGN_BIND_CHECKSUM=false
ARTIFACT_UPLOAD_TTL_SECONDS=3600
ARTIFACT_DOWNLOAD_TTL_SECONDS=60
ARTIFACT_MAX_BYTES=5368709120
ARTIFACT_STREAM_CHUNK_BYTES=1048576
ARTIFACT_UPLOAD_WRITE_HEARTBEAT_SECONDS=15
ARTIFACT_STAGING_CLEANUP_GRACE_SECONDS=7200
ARTIFACT_CLEANUP_CONFIRMATION_GRACE_SECONDS=60
ARTIFACT_CLEANUP_CLAIM_STALE_SECONDS=300
ARTIFACT_CLEANUP_HEARTBEAT_SECONDS=15
ARTIFACT_CLEANUP_RECONCILE_ENABLED=true
ARTIFACT_CLEANUP_RECONCILE_INTERVAL_SECONDS=30
ARTIFACT_CLEANUP_RECONCILE_STALE_SECONDS=120
ARTIFACT_CLEANUP_RECONCILE_BATCH_SIZE=32
ARTIFACT_FINALIZING_STALE_SECONDS=7200
ARTIFACT_RETRY_AFTER_SECONDS=5
ARTIFACT_ATTEMPT_MAX_SESSIONS=256
ARTIFACT_ATTEMPT_MAX_BYTES=107374182400
DATASET_UPLOAD_TTL_SECONDS=3600
DATASET_DOWNLOAD_TTL_SECONDS=60
DATASET_UPLOAD_MAX_BYTES=5368709120
DATASET_OWNER_MAX_SESSIONS=8
DATASET_OWNER_MAX_BYTES=21474836480
DATASET_UPLOAD_WRITE_STALE_SECONDS=300
DATASET_UPLOAD_WRITE_HEARTBEAT_SECONDS=15
DATASET_FINALIZING_STALE_SECONDS=1800
DATASET_FINALIZING_HEARTBEAT_SECONDS=30
DATASET_CLEANUP_LATE_WRITER_GRACE_SECONDS=7200
DATASET_CLEANUP_CONFIRMATION_GRACE_SECONDS=60
DATASET_RETRY_AFTER_SECONDS=5
DATASET_MAX_ENTRIES=10000
DATASET_MAX_FILE_UNCOMPRESSED_BYTES=2147483648
DATASET_MAX_TOTAL_UNCOMPRESSED_BYTES=21474836480
DATASET_MAX_COMPRESSION_RATIO=200
TEST_SET_UPLOAD_TTL_SECONDS=1800
TEST_SET_UPLOAD_WRITE_STALE_SECONDS=300
TEST_SET_UPLOAD_WRITE_HEARTBEAT_SECONDS=15
TEST_SET_FINALIZING_STALE_SECONDS=1800
TEST_SET_FINALIZING_HEARTBEAT_SECONDS=30
TEST_SET_CLEANUP_LATE_WRITER_GRACE_SECONDS=7200
TEST_SET_CLEANUP_CONFIRMATION_GRACE_SECONDS=60
TEST_SET_ITEM_MAX_BYTES=268435456
TEST_SET_OWNER_MAX_SESSIONS=64
TEST_SET_OWNER_MAX_BYTES=2147483648
TEST_SET_MAX_ITEMS=128
TEST_SET_MAX_DURATION_SECONDS=600
TEST_SET_MAX_TOTAL_DURATION_SECONDS=3600
TEST_SET_MIN_SAMPLE_RATE_HZ=8000
TEST_SET_MAX_SAMPLE_RATE_HZ=192000
TEST_SET_MAX_CHANNELS=2
SAMPLE_MAX_BYTES=268435456
SAMPLE_MAX_DURATION_SECONDS=600
SAMPLE_MAX_CHANNELS=2
SAMPLE_REGISTRATION_JSON_MAX_BYTES=65536
EXPERIMENT_JSON_MAX_BYTES=16384
USER_LIFECYCLE_JSON_MAX_BYTES=16384
WORKER_TELEMETRY_JSON_MAX_BYTES=2097152
SAMPLE_VERIFICATION_TIMEOUT_SECONDS=120
SAMPLE_VERIFICATION_MAX_CONCURRENCY=2
# Comma-separated approved pairs: sha256:<runtime-image-64hex>@<asset-manifest-64hex>
SAMPLE_APPROVED_RUNTIME_BUNDLES=
RATE_LIMIT_SAMPLE_REQUESTS_PER_MINUTE=30
RATE_LIMIT_SAMPLE_DOWNLOAD_REQUESTS_PER_MINUTE=60
WORKER_TOKEN_ROTATION_TTL_SECONDS=600
TEST_SET_DOWNLOAD_TIMEOUT_SECONDS=3600
TEST_SET_MATERIALIZATION_TIMEOUT_SECONDS=7200
TEST_SET_DOWNLOAD_MAX_ATTEMPTS=3
TEST_SET_MAX_ITEM_BYTES=268435456
TEST_SET_MAX_TOTAL_BYTES=2147483648
TEST_SET_DURATION_TOLERANCE_SECONDS=0.000001
# Keep false until lease-bound TestSet transfer, inference, Sample registration,
# and the Job completion gate pass the real runtime/GPU matrix.
AUTO_SAMPLE_JOBS_ENABLED=false
LEASE_SECONDS=120
WORKER_OFFLINE_SECONDS=180
LEASE_RECOVERY_MAX_ATTEMPTS=3

# The installer replaces this with /etc/rvc-orchestrator/manager/secrets.
# Every referenced file must contain one value without a trailing newline and
# must be readable only by root (or the deployment service account).
MANAGER_SECRETS_DIR=/etc/rvc-orchestrator/manager/secrets

# Worker settings (used with infra/compose/worker.compose.yml).
WORKER_COMPOSE_PROJECT_NAME=rvc-orchestrator-worker
MANAGER_URL=http://host.docker.internal:8080
WORKER_NAME=gpu-01
WORKER_DATA_ROOT=/var/lib/rvc-orchestrator/worker
WORKER_SECRETS_DIR=/etc/rvc-orchestrator/worker/secrets
# Leave empty to use the runtime image's default public CA trust. The installer
# only enables the fixed container path after validating --ca-bundle-file.
WORKER_CA_BUNDLE_PATH=
WORKER_CA_BUNDLE_HOST_DIR=/etc/rvc-orchestrator/worker/ca
RVC_RUNNER_MODE=fake
WORKER_RVC_PROFILE_HOST_PATH=/etc/rvc-orchestrator/worker/rvc-profile.yaml
RVC_NATIVE_SOURCE_ROOT=/opt/rvc-webui
RVC_NATIVE_PYTHON_EXECUTABLE=/opt/conda/bin/python
RVC_NATIVE_CPU_WORKERS=2
RVC_NATIVE_DEVICE=cuda
RVC_NATIVE_USE_HALF=true
RVC_NATIVE_PREPROCESS_TIMEOUT_SECONDS=3600
RVC_NATIVE_EXTRACTION_TIMEOUT_SECONDS=7200
RVC_NATIVE_TRAINING_TIMEOUT_SECONDS=604800
RVC_NATIVE_INDEX_TIMEOUT_SECONDS=86400
RVC_NATIVE_SMALL_MODEL_TIMEOUT_SECONDS=3600
RVC_GPU_SMOKE_VERIFIED=false
RVC_PROFILE_STAGE_SET_VERIFIED=false
RVC_NATIVE_UNVERIFIED_GPU_ACKNOWLEDGED=false
HEARTBEAT_INTERVAL_SECONDS=15
SYSTEM_TELEMETRY_INTERVAL_SECONDS=60
POLL_INTERVAL_SECONDS=5
LEASE_RENEW_INTERVAL_SECONDS=30
TELEMETRY_SPOOL_MAX_BYTES=268435456
ARTIFACT_UPLOAD_TIMEOUT_SECONDS=3600
ARTIFACT_UPLOAD_MAX_ATTEMPTS=3
ARTIFACT_MAX_OBJECT_BYTES=5368709120
ARTIFACT_MAX_FILES_PER_ATTEMPT=256
ARTIFACT_MAX_TOTAL_BYTES_PER_ATTEMPT=107374182400
ARTIFACT_CHECKPOINT_RETENTION=20
DATASET_DOWNLOAD_TIMEOUT_SECONDS=3600
DATASET_DOWNLOAD_MAX_ATTEMPTS=3
DATASET_MAX_ARCHIVE_BYTES=5368709120
DATASET_MAX_FILE_BYTES=2147483648
DATASET_MAX_TOTAL_BYTES=21474836480
